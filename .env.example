# ==============================================================================
# Ask Your Data - Environment Configuration
# Copy this file to '.env' and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------

# Environment: 'local' (offline developer sandbox) or 'production' (cloud settings)
# When set to 'local', the app uses SQLite locally for users and in-memory session services.
ENVIRONMENT=local

# Secret key used for signing and verifying JWT authentication tokens.
# Replace this with a secure, long random string in production (e.g., openssl rand -hex 32).
JWT_SECRET=dev-secret-key-change-me-in-production-123456789

# ------------------------------------------------------------------------------
# 2. GOOGLE CLOUD CONFIGURATION (Required for deployed / 'production' mode)
# ------------------------------------------------------------------------------

# Your Google Cloud Project ID (used to initialize Firestore clients)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud region location (e.g., 'us-central1' or 'europe-west1')
GOOGLE_CLOUD_LOCATION=global

# Google Cloud Storage (GCS) bucket name used for storing session artifacts
# (e.g., uploaded CSVs, generated plotly chart JSON files, and PDFs).
LOGS_BUCKET_NAME=your-gcs-artifacts-bucket-name

# ------------------------------------------------------------------------------
# 3. OPTIONAL DEVELOPER SETTINGS
# ------------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins. Left empty allows all origins.
ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
