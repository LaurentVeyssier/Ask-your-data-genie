# ==============================================================================
# Ask Your Data - Environment Configuration
# Copy this file to '.env' and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------

# Environment: 'local' (offline developer sandbox) or 'production' (cloud settings)
# When set to 'local', the app uses SQLite locally for users and in-memory session services.
# when set to 'production', the app uses Firestore for users and GCS for session artifacts.
ENVIRONMENT=local

# The Gemini model name to use for analysis and data analysis tasks.
# (e.g., 'gemini-3.5-flash', 'gemini-2.5-flash', or 'gemini-2.5-pro')
GEMINI_MODEL=gemini-3.5-flash

# Secret key used for signing and verifying JWT authentication tokens.
# Replace this with a secure, long random string in production (e.g., openssl rand -hex 32).
# produce using uv run python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-key-change-me-in-production-123456789

# Email of the primary Administrator account.
# On database startup, this user is automatically promoted to admin status.
ADMIN_EMAIL=admin@example.com

# ------------------------------------------------------------------------------
# 2. GOOGLE CLOUD CONFIGURATION (Required for deployed / 'production' mode)
# ------------------------------------------------------------------------------

# Your Google Cloud Project ID (used to initialize Firestore clients)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud region location (e.g., 'us-central1' or 'europe-west1')
# set to global so that Vertex AI to dynamically route requests to the most available region with the lowest latency and highest quota
GOOGLE_CLOUD_LOCATION=global

# Google Cloud Storage (GCS) bucket name used for storing session artifacts
# (e.g., uploaded CSVs, generated plotly chart JSON files, and PDFs).
LOGS_BUCKET_NAME=your-gcs-artifacts-bucket-name

# Backend selection: 'True' to use enterprise Vertex AI (GCP credentials required),
# or 'False' to use developer Gemini API (requires GEMINI_API_KEY below).
GOOGLE_GENAI_USE_VERTEXAI=True

# Gemini API Key (Required if GOOGLE_GENAI_USE_VERTEXAI=False)
# GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------------------------------------------
# 3. OPTIONAL DEVELOPER SETTINGS
# ------------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins. Left empty allows all origins.
ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Enable exporting OpenTelemetry traces to Google Cloud Trace (Trace Explorer)
# set to 'True' to route traces to the GCP project, 'False' to disable tracing.
ENABLE_CLOUD_TRACE=True
